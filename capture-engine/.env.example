# Interface to sniff on. Use `ifconfig` (mac/linux) or `ipconfig` (windows) to find yours.
INTERFACE=en0

# Node ingestion API
INGEST_URL=http://localhost:5000/api/internal/ingest
INGEST_API_KEY=change-me-shared-secret

# Detection tuning (overridable; server-side /api/rules also stores these for the dashboard)
PORT_SCAN_UNIQUE_PORTS=15
PORT_SCAN_WINDOW_SECONDS=10

DOS_PACKETS_PER_SECOND=200
DOS_WINDOW_SECONDS=5

ICMP_FLOOD_PACKETS=50
ICMP_FLOOD_WINDOW_SECONDS=5

SUSPICIOUS_PORTS=4444,31337,1337,6667,12345
